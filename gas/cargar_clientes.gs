var SHEET_ID_CLIENTES = "1Wbz8A2WDdNjcByDqpH1FRDm9XvuspyzMFIh7Ep9cIMI";
var HDRS_CLIENTES = ["cliente_nit","razon_social","vendedor_asignado","coordenadas_home","foto_fachada_url","telefono","ciudad","vendedor_datax"];

function iniciarCargaClientes() {
  var ss = SpreadsheetApp.openById(SHEET_ID_CLIENTES);
  var hoja = ss.getSheetByName("CLIENTES");
  if (!hoja) hoja = ss.insertSheet("CLIENTES");
  else hoja.clearContents();
  hoja.getRange(1,1,1,HDRS_CLIENTES.length).setValues([HDRS_CLIENTES]);
  hoja.getRange(1,1,1,HDRS_CLIENTES.length).setBackground("#1a3a5c").setFontColor("#fff").setFontWeight("bold");
  hoja.setFrozenRows(1);
  SpreadsheetApp.getUi().alert("Listo. Se borro la hoja CLIENTES anterior. Ahora ejecuta cargarClientesParte1");
}

function _cargarClientes(datos, parte, total_partes) {
  var ss = SpreadsheetApp.openById(SHEET_ID_CLIENTES);
  var hoja = ss.getSheetByName("CLIENTES");
  var ultima = hoja.getLastRow();
  hoja.getRange(ultima+1, 1, datos.length, HDRS_CLIENTES.length).setValues(datos);
  SpreadsheetApp.getUi().alert(
    "Parte " + parte + "/" + total_partes + " OK\n" +
    datos.length + " clientes cargados.\n" +
    "Total acumulado: " + hoja.getLastRow() + " filas.\n\n" +
    (parte < total_partes ? "Ahora ejecuta cargarClientesParte" + (parte+1) : "Carga de clientes completa. Total esperado: 1563")
  );
}

